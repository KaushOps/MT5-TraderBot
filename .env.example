# =============================================================================
# Exness MT5 AI Trading Agent — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# ── MetaTrader 5 Credentials (REQUIRED) ──────────────────────────────────────
MT5_LOGIN=12345678                  # Your Exness account number (numeric)
MT5_PASSWORD=your_mt5_password      # MT5 account password
MT5_SERVER=Exness-MT5Trial8         # Server name shown in MT5 terminal status bar

# ── Anthropic Claude (REQUIRED) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...        # From https://console.anthropic.com

# ── Trading Configuration ─────────────────────────────────────────────────────
# MT5 symbol names — Exness Zero uses no suffix for most instruments
ASSETS="BTCUSD ETHUSD XAUUSD EURUSD USOIL"
INTERVAL=5m                         # Candle interval: 1m 5m 15m 1h 4h 1d

LLM_MODEL=claude-sonnet-4-20250514  # Claude model to use
# SANITIZE_MODEL=claude-haiku-4-5-20251001  # Cheap model for output normalisation
# MAX_TOKENS=4096                   # Max LLM output tokens

# ── Risk Management ───────────────────────────────────────────────────────────
MAX_POSITION_PCT=10                 # Max single position as % of equity (default: 10)
MAX_LOSS_PER_POSITION_PCT=20        # Force-close position at this % unrealised loss (default: 20)
MAX_LEVERAGE=10                     # Hard leverage cap (default: 10)
MAX_TOTAL_EXPOSURE_PCT=50           # Max combined notional as % of equity (default: 50)
DAILY_LOSS_CIRCUIT_BREAKER_PCT=10   # Pause new trades at this daily drawdown % (default: 10)
MANDATORY_SL_PCT=2                  # Auto stop-loss distance % if Claude doesn't set one (default: 2)
MAX_CONCURRENT_POSITIONS=5          # Max simultaneous open positions (default: 5)
MIN_BALANCE_RESERVE_PCT=20          # Don't trade below this % of starting balance (default: 20)

# ── ATR-anchored TP/SL (Phase 1) ──────────────────────────────────────────────
# The risk manager enforces TP and SL distance as multiples of the intraday
# (5m) ATR14 at entry. This stops the LLM from picking unreachable moonshot TPs
# or absurdly tight SLs.
TP_ATR_MULT_MIN=0.8                 # Min TP distance in ATR multiples
TP_ATR_MULT_MAX=2.0                 # Max TP distance in ATR multiples
SL_ATR_MULT_MIN=0.8                 # Min SL distance in ATR multiples
SL_ATR_MULT_MAX=1.5                 # Max SL distance in ATR multiples
MIN_RR=1.2                          # Minimum reward:risk
MAX_RR=2.5                          # Maximum reward:risk (keeps TP reachable)
DEFAULT_SL_ATR_MULT=1.0             # Fallback SL if LLM returns null (ATR-based)
DEFAULT_TP_ATR_MULT=1.5             # Fallback TP if LLM returns null (ATR-based)

# ── Active Position Management (Phase 2 / 3) ──────────────────────────────────
# Each cycle the bot inspects open positions and (independently of the LLM):
# moves SL to breakeven, trails SL, tightens TP, and partial-closes profitable
# trades. This is the primary fix for "trade went into profit but the market
# flipped before TP was hit".
ENABLE_POSITION_MANAGER=true        # Master switch for phases 2/3
BREAKEVEN_ACTIVATE_R=0.8            # Move SL to entry once +R multiple reached
BREAKEVEN_BUFFER_ATR=0.05           # Small ATR buffer above/below entry
TRAIL_ACTIVATE_R=1.5                # Start trailing SL once +R reached
TRAIL_ATR_MULT=1.0                  # Trail distance in ATR multiples
TIGHTEN_TP_R=1.0                    # Pull TP in once +R reached
TIGHTEN_TP_ATR_MULT=1.0             # New TP distance in ATR multiples from price
PARTIAL_TP_R=1.0                    # Take partial profit once +R reached
PARTIAL_TP_FRACTION=0.5             # Fraction of position to close at +R

# ── Market Hours Filter ──────────────────────────────────────────────────────
# Skip assets whose market is currently closed (stocks on weekends, forex after
# Friday 22:00 UTC, etc.) and block new entries near session close to avoid
# overnight gap risk. Crypto is 24/7 and unaffected.
ENABLE_MARKET_HOURS=true            # Master switch
MAX_TICK_AGE_SEC=120                # Consider market closed if last tick is older
PRE_CLOSE_BLOCK_SEC=900             # Block new entries within N seconds of close

# ── MT5 Order Settings ────────────────────────────────────────────────────────
MT5_MAGIC=20260419                  # Magic number to tag all bot orders
MT5_SLIPPAGE=20                     # Max slippage in points

# ── API Server (optional) ─────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=3000

# ── Advanced Claude Settings (optional) ──────────────────────────────────────
# ENABLE_TOOL_CALLING=false         # Let Claude fetch extra indicators mid-decision
# THINKING_ENABLED=false            # Enable Claude extended thinking
# THINKING_BUDGET_TOKENS=10000
